        <mi>P</mi>
        <mo>=3D</mo>
        <mi>P</mi>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle \Box P=3DP}</=
annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/7f05811a3d025a0fa734e7254bbcab1607c85144" class=3D"mwe-math-fallback=
